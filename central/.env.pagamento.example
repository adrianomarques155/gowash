# ============================================================================
# GoWash central — variáveis da frente PAGAMENTO (Mercado Pago)
# ============================================================================
# Cole estas no Railway (serviço gowash → Variables). NUNCA no GitHub.
# As que você já tem (FIREBASE_SERVICE_ACCOUNT, CENTRAL_API_TOKEN) continuam.

# --- Mercado Pago ---
# Access Token da MESMA conta/aplicação que o ChargeTix já usa (decisão do
# Adriano: reaproveitar por enquanto — dá pra trocar de conta depois só
# atualizando esta variável). Copie direto do Railway do chargetix
# (serviço chargetix → Variables → MP_ACCESS_TOKEN), sem precisar retypar.
MP_ACCESS_TOKEN=

# Chave secreta da ASSINATURA deste webhook específico (HMAC). Cada URL de
# webhook cadastrada no painel MP tem a SUA PRÓPRIA assinatura — não é a
# mesma do ChargeTix. Painel MP → Webhooks → cadastra a URL do GoWash (ver
# abaixo) → copia a "Assinatura secreta" que aparece.
MP_WEBHOOK_SECRET=

# Segredo que vai no CAMINHO da URL do webhook (camada 1). Gere um novo e
# aleatório (ex.: openssl rand -hex 24) — tem que ser DIFERENTE do usado no
# ChargeTix. Tem que ser o MESMO valor cadastrado na notification_url no MP.
MP_WEBHOOK_PATH_SECRET=

# --- URLs públicas ---
# URL pública da própria central (para montar a notification_url do MP).
CENTRAL_PUBLIC_URL=https://gowash-production.up.railway.app
# URL do app-cliente (para onde o MP devolve o usuário após pagar).
APP_URL=https://gowash-fdyz.vercel.app

# ============================================================================
# No painel do Mercado Pago, cadastre o webhook em:
#   Webhooks → Nova notificação → URL:
#   https://gowash-production.up.railway.app/webhook/mercadopago/<MP_WEBHOOK_PATH_SECRET>
#   Evento: Pagamentos (payment)
# ============================================================================
